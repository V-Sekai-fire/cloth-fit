# Makefile for the PolyFEM NIF, compiled by elixir_make.
#
# Builds c_src/cloth_fit_cli/polyfem.cpp (Fine-based NIF) into priv/polyfem.<ext>.
# All include dirs, -D defines and the static libraries to link come from files
# generated by `mix cloth_fit.build_native`, so nothing platform-specific is
# hardcoded here:
#   * includes_CXX.rsp    - CMake's own include list for the polyfem target
#   * c_src/polyfem_defines.rsp - the exact -D defines PolyFEM compiles with
#   * c_src/polyfem_link.rsp    - the exact static libs (resolved per-OS),
#                                 already wrapped in a linker group
#
# Required env (provided by elixir_make):
#   FINE_INCLUDE_DIR  - Fine C++ headers (from Fine.include_dir/0)
#   ERTS_INCLUDE_DIR  - erl_nif.h and friends
POLYFEM_BUILD_DIR ?= $(abspath ../build)

PRIV_DIR = priv
SRC = c_src/cloth_fit_cli/polyfem.cpp

# NIF shared-library extension is platform specific. :erlang.load_nif/2 appends
# the OS suffix to the base path "priv/polyfem".
ifeq ($(OS),Windows_NT)
	NIF_EXT = dll
	SO_FLAGS = -shared
	# Statically link the llvm-mingw C++/unwind/pthread runtime so the NIF is
	# self-contained and can be bundled into a standalone Burrito binary without
	# shipping libc++.dll / libunwind.dll / libwinpthread-1.dll alongside it.
	SYS_LIBS = -static -lstdc++ -lm
else
	UNAME_S := $(shell uname -s)
	ifeq ($(UNAME_S),Darwin)
		NIF_EXT = so
		SO_FLAGS = -dynamiclib -undefined dynamic_lookup
		# macOS uses libc++ (system library, present everywhere); dlopen lives in
		# libSystem so there is no separate -ldl.
		SYS_LIBS = -lc++ -lm -lpthread
	else
		NIF_EXT = so
		SO_FLAGS = -shared -fPIC
		# Statically link libstdc++/libgcc so the NIF only needs libc at runtime
		# (it is loaded by a Burrito-bundled ERTS that has no system libstdc++).
		SYS_LIBS = -static-libstdc++ -static-libgcc -lstdc++ -lm -lpthread -ldl
	endif
endif

NIF = $(PRIV_DIR)/polyfem.$(NIF_EXT)

POLYFEM_INCLUDES_RSP = $(POLYFEM_BUILD_DIR)/CMakeFiles/polyfem.dir/includes_CXX.rsp
POLYFEM_DEFINES_RSP = c_src/polyfem_defines.rsp
POLYFEM_LINK_RSP = c_src/polyfem_link.rsp

CXX ?= g++
CXXFLAGS += -std=c++17 -O2 -fvisibility=hidden -fPIC

.PHONY: all clean
all: $(NIF)

$(NIF): $(SRC) $(POLYFEM_DEFINES_RSP) $(POLYFEM_LINK_RSP) | $(PRIV_DIR)
	$(CXX) $(CXXFLAGS) -I"$(FINE_INCLUDE_DIR)" -I"$(ERTS_INCLUDE_DIR)" \
		@$(POLYFEM_INCLUDES_RSP) @$(POLYFEM_DEFINES_RSP) $(SO_FLAGS) -o $@ $(SRC) \
		@$(POLYFEM_LINK_RSP) $(SYS_LIBS)

$(PRIV_DIR):
	mkdir -p $(PRIV_DIR)

clean:
	rm -f $(NIF)
